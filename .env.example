APP_NAME="Gestor Odontologico"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo
SYSTEM_VERSION=1.15.5

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

DEVELOPER_NAME=
DEVELOPER_EMAIL=
DEVELOPER_WHATSAPP=
DEVELOPER_SITE=
DEVELOPER_FOOTER_NOTE=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
# SQLite opcional apenas para ambiente local:
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

EVOLUTION_BASE_URL=
EVOLUTION_INSTANCE=
EVOLUTION_TOKEN=
EVOLUTION_WEBHOOK_SECRET=

VIACEP_BASE_URL=https://viacep.com.br/ws

WEBPUSH_SUBJECT=mailto:suporte@odontoflow.local
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=

ONBOARDING_AUTO_START=true

WHATSAPP_DISPATCH_ENABLED=false
WHATSAPP_RESPECT_BUSINESS_HOURS=true
WHATSAPP_BUSINESS_HOURS_START=08:00
WHATSAPP_BUSINESS_HOURS_END=18:00
WHATSAPP_MIN_INTERVAL_SECONDS=120
WHATSAPP_MAX_PER_MINUTE=10
WHATSAPP_MAX_PER_HOUR_PER_RECIPIENT=4
WHATSAPP_REQUIRE_OPT_IN=true
WHATSAPP_SIGNATURE="Equipe {{app_name}}"
WHATSAPP_DEFAULT_DELAY_MS=1500
WHATSAPP_LINK_PREVIEW=false

AUTOMATION_APPOINTMENT_REMINDER_ENABLED=true
AUTOMATION_APPOINTMENT_REMINDER_HOURS_BEFORE=24
AUTOMATION_FINANCIAL_DUE_ENABLED=true
AUTOMATION_FINANCIAL_DUE_DAYS_BEFORE=2
AUTOMATION_PATIENT_REACTIVATION_ENABLED=true
AUTOMATION_PATIENT_REACTIVATION_AFTER_DAYS=90
AUTOMATION_REACTIVATION_COOLDOWN_DAYS=30

VITE_APP_NAME="${APP_NAME}"
